<?php
/**
 * Настройки галереи и слайдера
 */

// Обработка сохранения
if($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['save_gallery'])) {
    // Слайдер вкл/выкл
    $slider_on = isset($_POST['slider_on']) ? '1' : '0';
    mysql_query("UPDATE ".MySQLprefix."_additional SET text='$slider_on' WHERE id=10");
    
    // Задержка слайдера
    $slider_delay = (int)$_POST['slider_delay'];
    mysql_query("UPDATE ".MySQLprefix."_additional SET text='$slider_delay' WHERE id=42");
    
    // Галерея вкл/выкл
    $gallery_on = isset($_POST['gallery_on']) ? '1' : '0';
    mysql_query("UPDATE ".MySQLprefix."_additional SET text='$gallery_on' WHERE id=6");
    
    $message = '<div style="background:#d4edda; color:#155724; padding:15px; border-radius:5px; margin-bottom:20px;">✅ Настройки сохранены!</div>';
    echo $message;
}

// Получаем текущие значения
$slider_on = mysql_result(mysql_query("SELECT text FROM ".MySQLprefix."_additional WHERE id=10"), 0);
$slider_delay = mysql_result(mysql_query("SELECT text FROM ".MySQLprefix."_additional WHERE id=42"), 0);
$gallery_on = mysql_result(mysql_query("SELECT text FROM ".MySQLprefix."_additional WHERE id=6"), 0);
?>

