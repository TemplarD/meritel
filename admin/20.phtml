// Обработка сохранения
if($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['save_settings'])) {
    // Скрыть цены
    $hide_prices = isset($_POST['hide_prices']) ? '1' : '0';
    mysql_query("UPDATE ".MySQLprefix."_additional SET text='$hide_prices' WHERE id=70");
    
    // Текст вместо цены
    $price_text = mysql_real_escape_string($_POST['price_text']);
    mysql_query("UPDATE ".MySQLprefix."_additional SET text='$price_text' WHERE id=71");
    
    // Телефон
    $phone = mysql_real_escape_string($_POST['phone']);
    mysql_query("UPDATE ".MySQLprefix."_additional SET text='$phone' WHERE id=4");
    
    // WhatsApp
    $whatsapp = mysql_real_escape_string($_POST['whatsapp']);
    mysql_query("UPDATE ".MySQLprefix."_additional SET text='$whatsapp' WHERE id=77");
    
    // Telegram username
    $telegram = mysql_real_escape_string($_POST['telegram']);
    mysql_query("UPDATE ".MySQLprefix."_additional SET text='$telegram' WHERE id=78");
    
    // Email для уведомлений
    $notify_email = mysql_real_escape_string($_POST['notify_email']);
    mysql_query("UPDATE ".MySQLprefix."_additional SET text='$notify_email' WHERE id=74");
    
    // Telegram Bot Token
    $tg_token = mysql_real_escape_string($_POST['tg_token']);
    mysql_query("UPDATE ".MySQLprefix."_additional SET text='$tg_token' WHERE id=72");
    
    // Telegram Chat ID
    $tg_chat_id = mysql_real_escape_string($_POST['tg_chat_id']);
    mysql_query("UPDATE ".MySQLprefix."_additional SET text='$tg_chat_id' WHERE id=73");
    
    // Включить Telegram уведомления
    $tg_enabled = isset($_POST['tg_enabled']) ? '1' : '0';
    mysql_query("UPDATE ".MySQLprefix."_additional SET text='$tg_enabled' WHERE id=75");
    
    // Включить Email уведомления
    $email_enabled = isset($_POST['email_enabled']) ? '1' : '0';
    mysql_query("UPDATE ".MySQLprefix."_additional SET text='$email_enabled' WHERE id=76");
    
    $message = '<div class="result-mess" style="position:fixed;left:50%;top:50%;margin:-50px 0 0 -200px;padding:30px;border:1px solid #fff;background:rgba(255,255,255,0.9);border-radius:20px;width:340px;height:40px;text-align:center;color:#000;font:16px/40px normal Arial;">✅ Настройки сохранены!</div>
    <script type="text/javascript">
    function rem_mes(){
        $(".result-mess").fadeOut(1000, function(){$(".result-mess").remove();});
    }
    var mto = window.setTimeout("rem_mes()",2000);
    </script>';
    echo $message;
}

